{
  "expo": {
    "name": "Global Zenith Bank",
    "slug": "global-zenith-bank",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0E11"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#0B0E11",
      "package": "com.globalzenithbank.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ]
  }
}
